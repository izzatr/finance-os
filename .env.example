# ─── Finance OS ───────────────────────────────────────────────────────────────
# Copy to .env and fill in values

# Edition: "community" (self-hosted, default) or "cloud" (hosted, multi-tenant)
FINANCE_OS_EDITION=community

# Database (Postgres)
DATABASE_URL=postgres://finance:***@localhost:27033/finance_os

# API server
PORT=27032

# Web app — points to the API
VITE_API_BASE_URL=http://localhost:27032
WEB_ORIGIN=http://localhost:27031

# ─── Better Auth ────────────────────────────────────────────────────────────────
# Required: secret for signing sessions and API keys (min 32 chars, random)
BETTER_AUTH_SECRET=change-me-to-a-random-32-plus-char-secret

# Allow new sign-ups. The very first user can always register (instance bootstrap).
# ALLOW_REGISTRATION=true

# ─── OAuth (optional — enable social login for web UI) ─────────────────────────
# Create apps at:
#   GitHub: https://github.com/settings/applications/new
#   Google: https://console.cloud.google.com/apis/credentials

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Self-hosted admin setup ────────────────────────────────────────────────
# On first launch, create an admin account with:
#   curl -X POST http://localhost:27032/auth/sign-up \
#     -H "Content-Type: application/json" \
#     -d '{"email":"admin@example.com","password":"your-password","name":"Admin"}'
#
# Then generate an API key via the web UI or:
#   curl -X POST http://localhost:27032/auth/api-key/create" \
#     -H "Content-Type: application/json" \
#     -d '{"userId":"<user-id-from-sign-up>","name":"CLI Key"}'

# AI assistant (optional — chat, natural-language quick-add, digest narratives)
# Get a key at https://openrouter.ai. Without it, AI features simply stay off.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Set to "true" ONLY when the API sits behind a reverse proxy that sets
# x-forwarded-for from the real client IP (the bundled nginx does).
# TRUST_PROXY=true

# Optional Yahoo Finance egress proxy for hosts whose outbound IP is rate-limited.
# Leave unset to call Yahoo directly. Configure this only on the API service.
# YAHOO_FINANCE_BASE_URL=https://your-restricted-worker.workers.dev
