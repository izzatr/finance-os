{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@finance-os/db": ["../../packages/db/src/index.ts"],
      "@finance-os/domain": ["../../packages/domain/src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
